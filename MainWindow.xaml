<Window x:Class="BotWhatsappCSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BotWhatsappCSharp"
        Title="BotZap AI - Painel Premium" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource BgApp}">
    
    <Window.Resources>
        <!-- Fontes -->
        <FontFamily x:Key="Inter">pack://application:,,,/Resources/#Inter</FontFamily>

        <!-- MODERN SAAS PALETTE (Clean Light) -->
        <SolidColorBrush x:Key="BgApp" Color="#F3F4F6"/> <!-- Light Gray 100 -->
        <SolidColorBrush x:Key="BgCard" Color="#FFFFFF"/> <!-- Pure White -->
        <SolidColorBrush x:Key="BrandPrimary" Color="#2563EB"/> <!-- Blue 600 -->
        <SolidColorBrush x:Key="TextDark" Color="#111827"/> <!-- Gray 900 -->
        <SolidColorBrush x:Key="TextGray" Color="#4B5563"/> <!-- Gray 600 -->
        <SolidColorBrush x:Key="SuccessGreen" Color="#059669"/> <!-- Emerald 600 -->
        <SolidColorBrush x:Key="DangerRed" Color="#DC2626"/> <!-- Red 600 -->
        <SolidColorBrush x:Key="BrandYellow" Color="#D97706"/> <!-- Amber 600 -->
        <SolidColorBrush x:Key="TextBlack" Color="#000000"/> 

        <!-- Conversores de Status de Ticket -->
        <local:BooleanToStatusBrushConverter x:Key="BooleanToStatusBrushConverter"/>
        <local:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
        <local:BooleanToStatusForegroundConverter x:Key="BooleanToStatusForegroundConverter"/>

        <!-- Sidebar Button Style -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/> 
                    <Setter Property="Foreground" Value="{StaticResource BrandPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="4" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input Style -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Margin="0,40,0,40">
                    <Image Source="/Assets/SidebarLogo.png" Height="50" Stretch="Uniform"/>
                    <TextBlock Text="PAINEL DE CONTROLE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" Margin="0,10,0,0" Opacity="0.7"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnNavEvoSetup" Content="⚙️  Evolution API" Style="{StaticResource NavBtnStyle}" Click="NavEvoSetup_Click"/>
                    <Button x:Name="BtnNavConnect" Content="🔌  Conexão" Style="{StaticResource NavBtnStyle}" Click="NavConnect_Click"/>
                    <Button x:Name="BtnNavAI" Content="🤖  Inteligência Artificial" Style="{StaticResource NavBtnStyle}" Click="NavAI_Click"/>
                    <Button x:Name="BtnNavTickets" Content="🎧  Atendimento Humano" Style="{StaticResource NavBtnStyle}" Click="NavTickets_Click">
                        <Button.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TemNovoChamado}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BrandYellow}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnNavBulk" Content="🚀  Disparo em Massa" Style="{StaticResource NavBtnStyle}" Click="NavBulk_Click"/>
                    <Button x:Name="BtnNavTriggers" Content="⚡  Gatilhos Rápidos" Style="{StaticResource NavBtnStyle}" Click="NavTriggers_Click"/>
                    <Button x:Name="BtnNavSchedule" Content="📅  Agendamentos" Style="{StaticResource NavBtnStyle}" Click="NavSchedule_Click"/>
                </StackPanel>
                
                <StackPanel Grid.Row="2" Margin="20" Opacity="0.6">
                    <Separator Background="{StaticResource BorderColor}" Margin="0,0,0,10"/>
                    <TextBlock Text="BotZap AI Premium" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextDark}"/>
                    <TextBlock Text="Versão 5.1 Estável" FontSize="11" Foreground="{StaticResource TextGray}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Margin="40">
            
            <!-- View: Conexão -->
            <StackPanel x:Name="ViewConnection" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Style="{StaticResource CardStyle}" Width="450">
                    <StackPanel>
                        <TextBlock Text="Conectar WhatsApp" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,8"/>
                        <TextBlock Text="Inicie a sessão para permitir que o bot interaja." FontSize="14" Foreground="{StaticResource TextGray}" Margin="0,0,0,24"/>

                        <Button x:Name="StartBtn" Content="INICIAR SISTEMA" Height="50" Style="{StaticResource PrimaryBtn}" Click="StartBtn_Click"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource TextGray}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="StatusLabel" Text="Desconectado" FontSize="14" Foreground="{StaticResource TextGray}"/>
                        </StackPanel>

                        <Button Content="🔄 Reconectar WhatsApp" Margin="0,12,0,0" Height="44" Background="#F3F4F6" Foreground="{StaticResource TextDark}" Click="ReconectarWA_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Limpar Sessão (Resetar Login)" Margin="0,40,0,0" 
                                Foreground="{StaticResource DangerRed}" Background="Transparent" 
                                BorderThickness="0" Click="ClearSession_Click" Cursor="Hand"
                                FontSize="12" Opacity="0.7">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>


            <!-- View: IA -->
            <StackPanel x:Name="ViewAI" Visibility="Collapsed">
                <TextBlock Text="Configuração da IA" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,5"/>
                <TextBlock Text="Gerencie como o bot pensa e responde." FontSize="14" Foreground="{StaticResource TextGray}" Margin="0,0,0,30"/>
                
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Chave API (Groq)" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" Margin="0,0,0,8"/>
                        <TextBox x:Name="ApiKeyInput" Style="{StaticResource ModernInput}" Tag="sk-..." Margin="0,0,0,20"/>

                        <TextBlock Text="Prompt do Sistema (Personalidade)" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" Margin="0,0,0,8"/>
                        <TextBox x:Name="SystemPromptInput" Height="120" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Style="{StaticResource ModernInput}" 
                                 Text="Você é um assistente virtual útil e educado."/>
                        
                        <Button Content="Salvar Alterações" Click="SaveAI_Click" Width="180" Height="40" Margin="0,20,0,0" HorizontalAlignment="Right" Style="{StaticResource PrimaryBtn}"/>

                        <Separator Background="{StaticResource BorderColor}" Margin="0,30"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="Status do Robô:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" Margin="0,0,10,0"/>
                            <Button x:Name="AiToggleBtn" Content="LIGAR ATENDIMENTO AUTOMÁTICO" Height="50"
                                Background="{StaticResource BrandYellow}" Foreground="{StaticResource TextBlack}"
                                FontWeight="Bold" Margin="0,0,0,10" Click="AiToggle_Click"/>
                        </StackPanel>
                        
                        <DockPanel Margin="0,0,0,20">
                            <Button x:Name="BtnPickAiFile" Content="📎 Anexo Global IA" Click="PickAiFile_Click" Width="140" Padding="5,2" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtAiFileName" Text="Nenhum arquivo (Fotos/Áudios)" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextGray}" FontStyle="Italic"/>
                        </DockPanel>

                        <TextBlock x:Name="AiStatusLabel" Text="STATUS: PARADO" FontWeight="SemiBold" 
                                   Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock Text="Logs do Sistema (Tempo Real)" Margin="0,10,0,5" FontWeight="Bold" Foreground="{StaticResource TextGray}"/>
                        <ListBox x:Name="LogList" Height="150" Background="#fdfdfd" BorderBrush="#ddd" FontFamily="Consolas" FontSize="11">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="5,2"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- View: Agendamentos (Calendário Visual) -->
            <Grid x:Name="ViewSchedule" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Agendamentos" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextGray}" Text="Clique nos horários para marcar como disponível"/>
                    </StackPanel>
                    
                    <!-- Navegação de mês -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnMesAnterior" Content="◀" Click="BtnMesAnterior_Click" Width="36" Height="36" Background="#E5E7EB" Foreground="{StaticResource TextDark}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock x:Name="TxtMesAtual" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0" MinWidth="140" TextAlignment="Center" Foreground="{StaticResource TextDark}"/>
                        <Button x:Name="BtnProximoMes" Content="▶" Click="BtnProximoMes_Click" Width="36" Height="36" Background="#E5E7EB" Foreground="{StaticResource TextDark}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Calendário -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Legenda -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="16" Height="16" CornerRadius="3" Background="#D1FAE5" Margin="0,0,6,0"/>
                            <TextBlock Text="Disponível" FontSize="12" Foreground="{StaticResource TextGray}" Margin="0,0,20,0"/>
                            <Border Width="16" Height="16" CornerRadius="3" Background="#FEE2E2" Margin="0,0,6,0"/>
                            <TextBlock Text="Agendado" FontSize="12" Foreground="{StaticResource TextGray}" Margin="0,0,20,0"/>
                            <Border Width="16" Height="16" CornerRadius="3" Background="#F3F4F6" Margin="0,0,6,0"/>
                            <TextBlock Text="Sem slot" FontSize="12" Foreground="{StaticResource TextGray}"/>
                        </StackPanel>

                        <!-- Grid do calendário gerado por código -->
                        <UniformGrid x:Name="CalendarioGrid" Columns="7" Rows="7"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- View: Disparo -->
            <StackPanel x:Name="ViewBulk" Visibility="Collapsed">
                <TextBlock Text="BOTZAP AI" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandYellow}" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <TextBlock Text="Disparo em Massa" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,30"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Numbers -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <Button x:Name="ImportContactsBtn" DockPanel.Dock="Top" Content="📂 Carregar Lista (.csv/.txt)" Height="40" Background="#E5E7EB" Foreground="{StaticResource TextDark}" Margin="0,0,0,15" Click="ImportContacts_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBox x:Name="BulkNumbersInput" AcceptsReturn="True" Style="{StaticResource ModernInput}" VerticalScrollBarVisibility="Auto"
                                     ToolTip="Cole os números aqui (um por linha)"/>
                        </DockPanel>
                    </Border>

                    <!-- Right: Message & Control -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Mensagem da Campanha" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" Margin="0,0,0,8"/>
                                <TextBox x:Name="BulkMessageInput" Height="120" AcceptsReturn="True" Style="{StaticResource ModernInput}" TextWrapping="Wrap"/>
                                
                                <!-- Mídia da campanha (opcional) -->
                                <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="Mídia da campanha (opcional)" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{StaticResource TextDark}"/>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" x:Name="BtnBulkImagem" Content="🖼️  Imagem" Click="BtnBulkImagem_Click" Height="44" Background="#E5E7EB" Foreground="{StaticResource TextDark}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Grid.Column="2" x:Name="BtnBulkPDF" Content="📄  PDF" Click="BtnBulkPDF_Click" Height="44" Background="#E5E7EB" Foreground="{StaticResource TextDark}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Grid.Column="4" x:Name="BtnBulkAudio" Content="🎵  Áudio" Click="BtnBulkAudio_Click" Height="44" Background="#E5E7EB" Foreground="{StaticResource TextDark}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <Border Margin="0,10,0,0" Padding="10,8" Background="#F9FAFB" CornerRadius="8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="✕" x:Name="BtnBulkRemoverMidia" Click="BtnBulkRemoverMidia_Click" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="{StaticResource DangerRed}" Visibility="Collapsed"/>
                                                <TextBlock x:Name="TxtBulkMidiaInfo" Text="Nenhuma mídia selecionada" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextGray}" FontStyle="Italic"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Configurações Anti-Ban (Stealth)" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" Margin="0,20,0,10"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Delay Min (seg)" FontSize="11" Foreground="{StaticResource TextGray}"/>
                                        <TextBox x:Name="BulkDelayMin" Style="{StaticResource ModernInput}" Text="5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Delay Max (seg)" FontSize="11" Foreground="{StaticResource TextGray}"/>
                                        <TextBox x:Name="BulkDelayMax" Style="{StaticResource ModernInput}" Text="15"/>
                                    </StackPanel>
                                </Grid>

                                <Button Content="📦 VER MODELO DE PLANILHA" Height="35" Margin="0,0,0,10" 
                                        Background="Transparent" BorderBrush="{StaticResource BrandPrimary}" 
                                        Foreground="{StaticResource BrandPrimary}" BorderThickness="1"
                                        Click="DownloadTemplate_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <TextBlock Text="Ações" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" Margin="0,5,0,10"/>
                                <Button x:Name="StartBulkBtn" Content="INICIAR ENVIO" Click="StartBulk_Click" Height="45" Margin="0,0,0,10" Style="{StaticResource PrimaryBtn}" Background="{StaticResource SuccessGreen}"/>
                                <Button Content="PARAR" Click="StopBulk_Click" Height="40" Background="{StaticResource DangerRed}" Foreground="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
                                <TextBlock x:Name="BulkStatusLabel" Text="Aguardando início..." Foreground="{StaticResource TextGray}" TextWrapping="Wrap" FontSize="12"/>
                                <ProgressBar x:Name="BulkProgressBar" Height="6" Minimum="0" Maximum="100" Value="0" Margin="0,8,0,0" Foreground="{StaticResource BrandPrimary}" Background="#E5E7EB"/>
                                <TextBlock x:Name="BulkProgressLabel" Text="" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- View: Gatilhos (Fixed) -->
            <StackPanel x:Name="ViewTriggers" Visibility="Collapsed">
                 <TextBlock Text="Gatilhos e Automação" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,5"/>
                 <TextBlock Text="Configure respostas automáticas. Use '/' para comandos exatos ou apenas palavras para palavras-chave." FontSize="14" Foreground="{StaticResource TextGray}" Margin="0,0,0,30"/>
                 
                 <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Input Area (New Split Design) -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Gatilho (Comando ou Palavra)" FontWeight="SemiBold" Foreground="{StaticResource TextGray}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TriggerCmdInput" Style="{StaticResource ModernInput}" ToolTip="Ex: /ajuda ou apenas 'preço'"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Resposta Automática" FontWeight="SemiBold" Foreground="{StaticResource TextGray}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TriggerRespInput" Style="{StaticResource ModernInput}" Tag="Sua chave pix é..."/>
                                
                                <StackPanel Margin="0,5,0,0">
                                  <TextBlock Text="Tipo de mídia" FontSize="11" Foreground="{StaticResource TextGray}"/>
                                  <ComboBox x:Name="CmbTipoMidia" Margin="0,4,0,6" SelectedIndex="0">
                                    <ComboBoxItem Content="Nenhum"/>
                                    <ComboBoxItem Content="Imagem (jpg, png, gif)"/>
                                    <ComboBoxItem Content="PDF"/>
                                    <ComboBoxItem Content="Áudio (mp3, ogg, opus)"/>
                                    <ComboBoxItem Content="Vídeo (mp4)"/>
                                  </ComboBox>

                                  <DockPanel>
                                    <Button x:Name="BtnPickFile" Content="📎 Selecionar arquivo" Click="PickTriggerFile_Click" Width="150" Padding="5,2" FontSize="11" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtFileName" Text="Nenhum arquivo selecionado" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextGray}" FontStyle="Italic"/>
                                  </DockPanel>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="4" Content="+ Adicionar" Click="AddTrigger_Click" Height="42" VerticalAlignment="Bottom" Width="100" Style="{StaticResource PrimaryBtn}"/>
                        </Grid>

                        <!-- List Area (Modern List) -->
                        <ListView x:Name="TriggersList" ItemsSource="{Binding Gatilhos}" Grid.Row="2" Height="400" BorderThickness="0" Background="Transparent" Foreground="{StaticResource TextDark}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Comando" Width="100" DisplayMemberBinding="{Binding Comando}"/>
                                    <GridViewColumn Header="Resposta" Width="380" DisplayMemberBinding="{Binding Resposta}"/>
                                    <GridViewColumn Header="Mídia" Width="90" DisplayMemberBinding="{Binding TipoMidiaAnexo}"/>
                                    <GridViewColumn Header="Arquivo(s)" Width="120" DisplayMemberBinding="{Binding NomeArquivo}"/>
                                    <GridViewColumn Header="Ação" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remover" Click="RemoveTrigger_Click" Foreground="{StaticResource DangerRed}" Background="Transparent" BorderThickness="0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                 </Border>
            </StackPanel>

            <!-- View: Tickets (Atendimento Humano) -->
            <StackPanel x:Name="ViewTickets" Visibility="Collapsed">
                <TextBlock Text="Atendimento Humano" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,5"/>
                <TextBlock Text="Gerencie conversas que precisam de intervenção manual." FontSize="14" Foreground="{StaticResource TextGray}" Margin="0,0,0,30"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="600">
                    <ItemsControl x:Name="TicketsList" ItemsSource="{Binding ChamadosAbertos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,10,12" Padding="20" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="2" Opacity="0.04"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Nome e número -->
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="{Binding Nome}" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                            <TextBlock FontSize="13" Foreground="#6B7280" Margin="0,2,0,0">
                                                <Run Text="📱 "/>
                                                <Run Text="{Binding Numero}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Horário e Status -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="#9CA3AF" Text="{Binding Horario, StringFormat={}{0:dd/MM HH:mm}}" HorizontalAlignment="Right"/>
                                            <Border Margin="0,4,0,0" Padding="8,3" CornerRadius="12" Background="{Binding Respondido, Converter={StaticResource BooleanToStatusBrushConverter}, FallbackValue='#FEF3C7'}">
                                                <TextBlock Text="{Binding Respondido, Converter={StaticResource BooleanToStatusTextConverter}, FallbackValue='Aguardando'}" FontSize="10" FontWeight="Bold" Foreground="{Binding Respondido, Converter={StaticResource BooleanToStatusForegroundConverter}, FallbackValue='#92400E'}" HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Última mensagem -->
                                        <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="10,8" CornerRadius="6" Background="#F9FAFB">
                                            <TextBlock Text="{Binding UltimaMensagem}" FontSize="13" Foreground="#374151" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                        </Border>

                                        <!-- Área de resposta rápida -->
                                        <Grid Grid.Row="4" Grid.ColumnSpan="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0" Tag="{Binding Numero}" Padding="10,8" FontSize="13" BorderBrush="#D1D5DB" BorderThickness="1">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Border Background="#F9FAFB" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <Button Grid.Column="2" Content="✉️ Responder" Click="ResponderTicket_Click" Tag="{Binding Numero}" Height="36" Background="{StaticResource BrandPrimary}" Foreground="White" FontWeight="Bold" FontSize="12">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Grid.Column="4" Content="✅ Concluir" Click="ResolveTicket_Click" Tag="{Binding Numero}" Height="36" Background="{StaticResource SuccessGreen}" Foreground="White" FontWeight="Bold" FontSize="12">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
