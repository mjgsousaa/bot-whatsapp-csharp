<Window x:Class="BotWhatsappCSharp.Views.SlotsDiaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Horários" Height="550" Width="400"
        WindowStartupLocation="CenterOwner" Background="#F3F4F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtData" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Selecione os horários de início disponíveis" FontSize="13" Foreground="#4B5563"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsSlots">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Margin="0,0,0,8" Padding="12" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox IsChecked="{Binding IsAvailable}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="{Binding StatusInfo}" FontSize="12" Foreground="{Binding StatusColor}"/>
                                </StackPanel>

                                <Border Grid.Column="2" Visibility="{Binding IsBookedVisible}" Background="#FEE2E2" Padding="8,4" CornerRadius="4">
                                    <TextBlock Text="RESERVADO" FontSize="10" FontWeight="Bold" Foreground="#991B1B"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Click="Cancel_Click" Width="100" Height="38" Background="Transparent" Foreground="#4B5563" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,10,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Salvar Slots" Click="Save_Click" Width="120" Height="38" Background="#2563EB" Foreground="White" FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
